# OpenRouter API kaliti (https://openrouter.ai/keys dan olasiz)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenRouter orqali LLM modeli
# Bepul variantlar: meta-llama/llama-3.3-70b-instruct:free, deepseek/deepseek-chat-v3-0324:free
# Arzon variantlar: openai/gpt-4o-mini, google/gemini-2.0-flash-exp:free
LLM_MODEL=meta-llama/llama-3.3-70b-instruct:free

# OpenRouter orqali embedding modeli
# Arzon va sifatli: openai/text-embedding-3-small ($0.02 / 1M token)
EMBEDDING_MODEL=openai/text-embedding-3-small

# Telegram bot tokeni (@BotFather dan olasiz)
TELEGRAM_BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Vector database saqlanadigan papka
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=phones

# Telefon ma'lumotlari fayli
PHONES_DATA_PATH=./data/phones.json

# Qidiruv uchun eng yaqin N ta natija
TOP_K_RESULTS=5
